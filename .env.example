# ============================================================================
# Variáveis de ambiente — EXEMPLO (servidor)
# ============================================================================
# Copie para `.env` (NÃO commitado) e preencha os valores reais.
# IMPORTANTE: nenhuma destas é segredo do cliente — NUNCA prefixe com
# NEXT_PUBLIC_. Tudo aqui é server-only (nada do backend vaza para o front).
# ----------------------------------------------------------------------------

# PostgreSQL no Neon — string POOLED (host com "-pooler"), usada em runtime.
DATABASE_URL=""

# PostgreSQL no Neon — string DIRECT (sem "-pooler"), usada por `prisma migrate`.
DIRECT_URL=""

# Segredo do Auth.js (gere com: npx auth secret).
AUTH_SECRET=""
