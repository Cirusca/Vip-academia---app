// ============================================================================
// prisma/schema.prisma — [NOME_DO_APP] (app de treino B2B2C)
// ----------------------------------------------------------------------------
// Prisma 7.8 + PostgreSQL + Auth.js v5 (@auth/prisma-adapter).
// Multi-tenant por gymId (derivado da sessão, NUNCA do cliente).
// Soft delete (status/deletedAt) nas entidades com histórico.
//
// ESCOPO: esta é a 1a migração (Fase 1 = "init_auth_and_core"):
//   Auth.js (Account/Session/VerificationToken) + User + WorkoutPlan + Exercise.
//   Assignment(Fase2), Link(Fase3), WorkoutLog/ExerciseLog(Fase3), Profile(Fase4)
//   entram por migrações ADITIVAS, com seus campos e relações, depois.
// ============================================================================

generator client {
  provider = "prisma-client"
  output   = "../lib/generated/prisma"
}

datasource db {
  // Prisma 7: as URLs de conexão ficam em prisma.config.ts (migrate usa DIRECT_URL)
  // e o PrismaClient recebe um `adapter` em runtime. Não declarar url/directUrl aqui.
  provider = "postgresql"
}

// ============================================================================
// ENUMS (Fase 1)
// ============================================================================

enum Role {
  profissional
  aluno
}

enum UserStatus {
  ativo
  inativo // soft delete da conta (RN-INV-03)
}

enum WorkoutPlanStatus {
  ativo
  inativo // soft delete do plano (RN-PLA-08)
}

// Fase 2 — estados da atribuição (RN-ATR-05). Apenas `ativa` vira treino do dia.
enum AssignmentStatus {
  ativa
  pausada
  concluida
}

// ============================================================================
// AUTH.JS v5 — contrato do @auth/prisma-adapter (não renomear campos).
// Com session.strategy = "jwt" (Fase 1.3), Session e VerificationToken ficam
// INERTES (vazias) no MVP, mas as tabelas são exigidas pelo adapter.
// ============================================================================

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique // RN-USR-02 (email = login, único por pessoa)
  emailVerified DateTime?
  image         String?

  // ---- Domínio (RN-USR) ----------------------------------------------------
  roles              Role[]     @default([]) // acúmulo de papéis (RN-USR-08)
  passwordHash       String? // NUNCA expor por select default (RN-SEG)
  status             UserStatus @default(ativo) // soft delete da conta
  mustChangePassword Boolean    @default(false) // reset manual (Fase 1.4)
  gymId              String // tenant — derivado da sessão
  cref               String? // profissional (RN-USR-05); unicidade via índice parcial (SQL)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? // par com status=inativo

  accounts     Account[]
  sessions     Session[]
  workoutPlans WorkoutPlan[] @relation("PlanOwner")

  // Fase 2 — atribuições recebidas (como aluno) e feitas (como profissional).
  assignmentsReceived Assignment[] @relation("AssignmentAluno")
  assignmentsMade     Assignment[] @relation("AssignmentAssigner")

  linksAsProfissional Link[] @relation("LinkProfessional")
  linksAsAluno        Link[] @relation("LinkAluno")

  workoutLogs WorkoutLog[] @relation("WorkoutLogAluno")

  @@index([gymId, status])
  @@index([gymId, deletedAt])
  @@map("users")
}

model Account {
  id                       String  @id @default(cuid())
  userId                   String
  type                     String
  provider                 String
  providerAccountId        String
  refresh_token            String?
  access_token             String?
  expires_at               Int?
  token_type               String?
  scope                    String?
  id_token                 String?
  session_state            String?
  refresh_token_expires_in Int?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ============================================================================
// NÚCLEO FASE 1 — WorkoutPlan + Exercise
// ============================================================================

model WorkoutPlan {
  id          String            @id @default(cuid())
  gymId       String // tenant — toda query escopada por gymId
  createdBy   String // dono = profissional (RN-PLA-01/02)
  name        String
  day         String? // rótulo (ex.: "Treino A" / "Segunda")
  estDuration Int? // minutos (numérico; exibido como faixa na UI — RN-PLA-07)
  estCalories Int? // kcal (numérico)
  level       String? // iniciante|intermediário|avançado (RN-PLA-06; enum em zod)
  status      WorkoutPlanStatus @default(ativo) // soft delete (RN-PLA-08)

  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  owner       User         @relation("PlanOwner", fields: [createdBy], references: [id], onDelete: Restrict)
  exercises   Exercise[]
  assignments Assignment[] // Fase 2 — a quem este plano foi atribuído
  workoutLogs WorkoutLog[]

  @@index([gymId, status])
  @@index([gymId, createdBy, status]) // quota RN-LIM-01 (<=50 planos/prof)
  @@map("workout_plans")
}

model Exercise {
  id            String  @id @default(cuid())
  workoutPlanId String
  name          String
  sets          Int // RN-PLA-04 / RN-INV-04: sets >= 1 (CHECK em SQL)
  reps          String // faixa "8-12" (RN-PLA-04)
  rest          String // descanso "60s"
  muscle        String
  videoUrl      String?
  instructions  String?
  order         Int // ordem significativa, 1-based (RN-PLA-05); única por plano

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)

  @@unique([workoutPlanId, order]) // não há duas posições iguais no mesmo plano
  @@index([workoutPlanId, order]) // leitura ordenada
  @@map("exercises")
}

// ============================================================================
// FASE 2 — Assignment (atribuição de plano a aluno)
// ----------------------------------------------------------------------------
// RN-ATR: o profissional ATRIBUI um plano que lhe pertence a um aluno do mesmo
// gym. A atribuição REFERENCIA o plano (não copia) — edições do plano refletem
// nas atribuições ativas (RN-ATR-06). Um plano serve a vários alunos e um aluno
// pode ter vários planos (RN-ATR-03). `gymId` é denormalizado p/ escopar toda
// query por tenant sem join.
// ============================================================================

model Assignment {
  id            String           @id @default(cuid())
  gymId         String // tenant — derivado da sessão, nunca do cliente
  workoutPlanId String
  alunoId       String
  assignedBy    String // profissional que atribuiu (RN-ATR-01)
  status        AssignmentStatus @default(ativa) // RN-ATR-05
  assignedAt    DateTime         @default(now())

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Cascade)
  aluno       User        @relation("AssignmentAluno", fields: [alunoId], references: [id], onDelete: Cascade)
  assigner    User        @relation("AssignmentAssigner", fields: [assignedBy], references: [id], onDelete: Restrict)

  @@index([gymId, alunoId, status]) // aluno lista seus planos atribuídos ativos (RN-ATR-04)
  @@index([gymId, workoutPlanId, status]) // profissional vê a quem um plano foi atribuído
  // RN-ATR-08 ("1 atribuição ativa por par") = índice PARCIAL único em SQL bruto na migração.
  @@map("assignments")
}

// ============================================================================
// FASE 3 — Link (vínculo profissional ↔ aluno)
// ----------------------------------------------------------------------------
// Profissional cria convite (inviteCode gerado no servidor) → aluno aceita com
// o código → Link passa de pendente→ativo. Encerrar → inativo + cascade de
// atribuições para pausada. Partial unique "1 ativo por aluno por gym" em SQL.
// ============================================================================

enum LinkStatus {
  pendente
  ativo
  inativo
}

model Link {
  id              String     @id @default(cuid())
  gymId           String
  professionalId  String
  alunoId         String?    // null até o aceite
  status          LinkStatus @default(pendente)
  inviteCode      String?    // null após aceite (consumido, one-time)
  inviteExpiresAt DateTime?
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt

  professional User  @relation("LinkProfessional", fields: [professionalId], references: [id], onDelete: Restrict)
  aluno        User? @relation("LinkAluno", fields: [alunoId], references: [id], onDelete: Restrict)

  @@index([gymId, professionalId, status])
  @@index([gymId, alunoId, status])
  // RN-VIN-03: 1 link ativo por aluno por gym → índice parcial único em SQL
  @@map("links")
}

// ============================================================================
// FASE 3 — WorkoutLog + ExerciseLog (execução de treino)
// ----------------------------------------------------------------------------
// WorkoutLog: sessão de treino em_andamento→concluido. ExerciseLog: snapshot
// dos exercícios no momento de iniciar (RN-EXE-09) — sem FK para exercises,
// tornando o histórico imutável (RN-EXE-07) mesmo que o plano seja editado.
// ============================================================================

enum WorkoutLogStatus {
  em_andamento
  concluido
}

model WorkoutLog {
  id             String           @id @default(cuid())
  gymId          String
  alunoId        String
  workoutPlanId  String
  status         WorkoutLogStatus @default(em_andamento)
  date           DateTime?        @db.Date  // data local Sao_Paulo; definida ao concluir
  startedAt      DateTime         @default(now())
  concludedAt    DateTime?
  durationMin    Int?             // calculado ao concluir (now − startedAt)
  caloriesBurned Int?             // estimativa do plano (estCalories)
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  aluno       User        @relation("WorkoutLogAluno", fields: [alunoId], references: [id], onDelete: Restrict)
  workoutPlan WorkoutPlan @relation(fields: [workoutPlanId], references: [id], onDelete: Restrict)
  exerciseLogs ExerciseLog[]

  @@index([gymId, alunoId, status])
  @@index([gymId, alunoId, date])
  // Partial unique: 1 log em_andamento por par (alunoId, workoutPlanId) → em SQL
  @@map("workout_logs")
}

model ExerciseLog {
  id           String     @id @default(cuid())
  workoutLogId String
  // Snapshot dos dados do exercício no momento de iniciar (RN-EXE-09).
  // Sem FK para exercises — isola do plano editável (RN-EXE-07).
  name         String
  sets         Int
  reps         String
  rest         String
  muscle       String
  videoUrl     String?
  instructions String?
  order        Int        // para ordenação na UI
  // Estado do exercício nesta sessão
  completed    Boolean    @default(false)
  createdAt    DateTime   @default(now())
  updatedAt    DateTime   @updatedAt

  workoutLog WorkoutLog @relation(fields: [workoutLogId], references: [id], onDelete: Cascade)

  @@index([workoutLogId, order])
  @@map("exercise_logs")
}
